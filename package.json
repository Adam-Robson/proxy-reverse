{
	"name": "@responsedotok/nrp",
	"version": "1.0.0",
	"type": "module",
	"description": "A composable, zero-dependency Node.js reverse proxy with routing, load balancing, WebSocket support, and lifecycle hooks",
	"main": "dist/src/index.js",
	"module": "dist/src/index.js",
	"types": "dist/src/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"module": "./dist/src/index.js",
			"require": "./dist/src/index.js"
		}
	},
	"bin": {
		"nrp": "./dist/src/index.js"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "node scripts/build.mjs",
		"dev": "tsc --watch",
		"test": "vitest",
		"lint": "biome check src",
		"format": "biome format --write src",
		"prepublishOnly": "npm run build && npm run test",
		"start": "node dist/src/index.js"
	},
	"author": "Adam Robson",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@types/node": "25.5.0",
		"typescript": "6.0.2",
		"vitest": "4.1.2"
	}
}
